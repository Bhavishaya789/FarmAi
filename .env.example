# Copy this file to .env and fill in your credentials

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/farmai

# EmailJS credentials (from emailjs.com dashboard)
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_WELCOME_TEMPLATE_ID=template_welcome
EMAILJS_VERIFY_TEMPLATE_ID=template_verify

# JWT secret key (any long random string)
JWT_SECRET=change_this_to_a_long_random_secret
